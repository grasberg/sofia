# Logrotate configuration for system logs (syslog, auth, etc.)
/var/log/syslog
/var/log/messages
/var/log/auth.log
/var/log/daemon.log
/var/log/kern.log
/var/log/user.log
{
    daily
    missingok
    rotate 7
    compress
    delaycompress
    notifempty
    create 0640 root adm
    sharedscripts
    postrotate
        /usr/lib/rsyslog/rsyslog-rotate
    endscript
}