# Logrotate configuration for Laravel application logs
/var/www/*/storage/logs/*.log {
    daily
    missingok
    rotate 30
    compress
    delaycompress
    notifempty
    create 0640 www-data www-data
    sharedscripts
    postrotate
        # Optional: clear Laravel log cache if using configured channels
        # cd /var/www/affiliate-system && php artisan log:clear > /dev/null 2>&1 || true
    endscript
}