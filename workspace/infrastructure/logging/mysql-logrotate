# Logrotate configuration for MySQL/MariaDB
/var/log/mysql/*.log
/var/log/mysql/error.log
{
    daily
    missingok
    rotate 7
    compress
    delaycompress
    notifempty
    create 640 mysql adm
    sharedscripts
    postrotate
        # MySQL 5.6 and earlier:
        # test -x /usr/bin/mysqladmin && /usr/bin/mysqladmin flush-logs
        # MySQL 5.7+ and MariaDB:
        if [ -d /var/lib/mysql ]; then
            /usr/bin/mysqladmin flush-logs > /dev/null 2>&1
        fi
    endscript
}