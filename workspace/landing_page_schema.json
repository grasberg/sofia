{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://example.com/landing-page-config.schema.json",
  "title": "Landing Page Configuration",
  "description": "Configuration format for digital product landing pages",
  "type": "object",
  "required": ["product_id", "product_name", "currency", "base_price"],
  "properties": {
    "product_id": {
      "type": "string",
      "description": "Unique product identifier"
    },
    "product_name": {
      "type": "string",
      "description": "Product name"
    },
    "product_slug": {
      "type": "string",
      "description": "URL-friendly product name"
    },
    "product_type": {
      "type": "string",
      "enum": ["digital_download", "course", "consultation", "software", "template", "bundle"],
      "default": "digital_download"
    },
    "category": {
      "type": "string",
      "description": "Product category"
    },
    "tags": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "default": []
    },
    "language": {
      "type": "string",
      "default": "sv"
    },
    "status": {
      "type": "string",
      "enum": ["draft", "published", "archived"],
      "default": "draft"
    },
    "currency": {
      "type": "string",
      "description": "Currency code (SEK, USD, EUR)"
    },
    "base_price": {
      "type": "number",
      "description": "Base price in the specified currency",
      "minimum": 0
    },
    "discount_price": {
      "type": "number",
      "description": "Discounted price (optional)"
    },
    "discount_end_date": {
      "type": "string",
      "format": "date",
      "description": "Discount end date (YYYY-MM-DD)"
    },
    "payment_type": {
      "type": "string",
      "enum": ["one_time", "subscription", "pay_what_you_want"],
      "default": "one_time"
    },
    "subscription_interval": {
      "type": "string",
      "enum": ["monthly", "yearly"],
      "description": "Required if payment_type is subscription"
    },
    "affiliate_percentage": {
      "type": "number",
      "minimum": 0,
      "maximum": 100
    },
    "tiers": {
      "type": "array",
      "description": "Product tiers/pricing plans",
      "items": {
        "type": "object",
        "required": ["tier_id", "tier_name", "price"],
        "properties": {
          "tier_id": {
            "type": "string"
          },
          "tier_name": {
            "type": "string"
          },
          "price": {
            "type": "number"
          },
          "currency": {
            "type": "string"
          },
          "features": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "description": {
            "type": "string"
          },
          "cta_text": {
            "type": "string",
            "default": "Köp nu"
          },
          "highlight": {
            "type": "boolean",
            "default": false
          }
        }
      }
    },
    "short_description": {
      "type": "string",
      "description": "Short description for preview"
    },
    "long_description": {
      "type": "string",
      "description": "Long description (markdown supported)"
    },
    "benefits": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "target_audience": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "how_it_works": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "Step-by-step instructions"
    },
    "delivery_method": {
      "type": "string",
      "enum": ["digital_download", "email", "platform_access"],
      "default": "digital_download"
    },
    "delivery_format": {
      "type": "string"
    },
    "delivery_instant": {
      "type": "boolean",
      "default": true
    },
    "access_duration": {
      "type": "string",
      "enum": ["lifetime", "1_year", "6_months", "3_months", "1_month"],
      "default": "lifetime"
    },
    "updates_included": {
      "type": "boolean",
      "default": true
    },
    "license_type": {
      "type": "string",
      "enum": ["personal", "commercial", "resell_rights"],
      "default": "personal"
    },
    "media": {
      "type": "object",
      "properties": {
        "hero_image": {
          "type": "string",
          "description": "Path or URL to hero image"
        },
        "product_images": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "demo_video_url": {
          "type": "string",
          "format": "uri"
        },
        "thumbnail_image": {
          "type": "string"
        },
        "preview_file": {
          "type": "string"
        }
      }
    },
    "sections": {
      "type": "array",
      "description": "Landing page sections",
      "items": {
        "type": "object",
        "required": ["section_id", "section_type", "title"],
        "properties": {
          "section_id": {
            "type": "string"
          },
          "section_type": {
            "type": "string",
            "enum": ["hero", "features", "pricing", "testimonials", "faq", "how_it_works", "cta", "guarantee"]
          },
          "title": {
            "type": "string"
          },
          "content": {
            "type": ["string", "array", "object"],
            "description": "Content depends on section_type"
          },
          "order": {
            "type": "integer",
            "minimum": 0
          },
          "visible": {
            "type": "boolean",
            "default": true
          }
        }
      }
    },
    "utm_campaign": {
      "type": "string"
    },
    "affiliate_code": {
      "type": "string"
    },
    "pixel_ids": {
      "type": "object",
      "properties": {
        "facebook": {
          "type": "string"
        },
        "google": {
          "type": "string"
        },
        "linkedin": {
          "type": "string"
        }
      }
    },
    "email_integration": {
      "type": "boolean",
      "default": false
    },
    "email_list": {
      "type": "string"
    },
    "platform_specific": {
      "type": "object",
      "properties": {
        "gumroad": {
          "type": "object",
          "description": "Gumroad-specific settings"
        },
        "stripe": {
          "type": "object",
          "description": "Stripe-specific settings"
        },
        "sendowl": {
          "type": "object",
          "description": "SendOwl-specific settings"
        }
      }
    }
  }
}